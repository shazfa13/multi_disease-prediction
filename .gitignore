.mypy_cache/
.ruff_cache/
.pyre/

# IDE / editor files
.vscode/
.idea/
*.swp
*.swo

# OS files
.DS_Store
Thumbs.db

# Environment / secrets
.env
.env.*
!.env.example

# Flask / app runtime artifacts
instance/
*.log

# Local database
*.db

# Project generated files
static/uploads/
static/heatmaps/

